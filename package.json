{
  "name": "liforce-backend",
  "description": "LiForce API and WebSocket server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "nodemon src/index.ts",
    "build": "tsc && prisma generate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:seed": "ts-node -O '{\"module\": \"commonjs\", \"types\": [\"node\"]}' prisma/seed.ts"
  },
  "prisma": {
    "seed": "ts-node -O '{\"module\": \"commonjs\", \"types\": [\"node\"]}' prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@prisma/client": "^5.16.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^6.9.14",
    "socket.io": "^4.7.5",
    "twilio": "^5.2.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.15",
    "nodemon": "^3.1.4",
    "prisma": "^5.16.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  }
}
